{
  "name": "netresearch/composer-agent-skill-plugin",
  "description": "Composer plugin for managing AI agent skills",
  "type": "composer-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Netresearch DTT GmbH",
      "email": "plugins@netresearch.de",
      "homepage": "https://www.netresearch.de/",
      "role": "Manufacturer"
    }
  ],
  "require": {
    "php": "^8.4",
    "composer-plugin-api": "2.2.*|^2.9",
    "symfony/yaml": "^5.4|^6.0|^7.0|^8.0",
    "symfony/console": "^5.4|^6.0|^7.0|^8.0"
  },
  "require-dev": {
    "composer/composer": "2.2.*|^2.9",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.0",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Netresearch\\ComposerAgentSkillPlugin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Netresearch\\ComposerAgentSkillPlugin\\Tests\\": "tests/"
    }
  },
  "extra": {
    "class": "Netresearch\\ComposerAgentSkillPlugin\\SkillPlugin"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
